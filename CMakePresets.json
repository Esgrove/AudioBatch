{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 4,
    "minor": 2,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2026-base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-ninja-msvc-base",
      "hidden": true,
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl",
        "CMAKE_CXX_COMPILER": "cl"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "macos-ninja-base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Darwin"
      }
    },
    {
      "name": "windows-debug",
      "displayName": "Windows Debug",
      "description": "Use Visual Studio 18 2026 with x64 output in cmake-build-windows-debug.",
      "inherits": "windows-vs2026-base",
      "binaryDir": "${sourceDir}/cmake-build-windows-debug"
    },
    {
      "name": "windows-release",
      "displayName": "Windows Release",
      "description": "Use Visual Studio 18 2026 with x64 output in cmake-build-windows-release.",
      "inherits": "windows-vs2026-base",
      "binaryDir": "${sourceDir}/cmake-build-windows-release"
    },
    {
      "name": "windows-ninja-debug",
      "displayName": "Windows Ninja Debug",
      "description": "Use Ninja with the MSVC toolchain in cmake-build-windows-ninja-debug for compile_commands.json support.",
      "inherits": "windows-ninja-msvc-base",
      "binaryDir": "${sourceDir}/cmake-build-windows-ninja-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-ninja-release",
      "displayName": "Windows Ninja Release",
      "description": "Use Ninja with the MSVC toolchain in cmake-build-windows-ninja-release for compile_commands.json support.",
      "inherits": "windows-ninja-msvc-base",
      "binaryDir": "${sourceDir}/cmake-build-windows-ninja-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos-debug",
      "displayName": "macOS Debug",
      "description": "Use Ninja with clang output in cmake-build-mac-debug.",
      "inherits": "macos-ninja-base",
      "binaryDir": "${sourceDir}/cmake-build-mac-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release",
      "description": "Use Ninja with clang output in cmake-build-mac-release.",
      "inherits": "macos-ninja-base",
      "binaryDir": "${sourceDir}/cmake-build-mac-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "windows-ninja-debug",
      "configurePreset": "windows-ninja-debug"
    },
    {
      "name": "windows-ninja-release",
      "configurePreset": "windows-ninja-release"
    },
    {
      "name": "macos-debug",
      "configurePreset": "macos-debug"
    },
    {
      "name": "macos-release",
      "configurePreset": "macos-release"
    }
  ]
}
